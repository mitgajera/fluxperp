# Anchor / Rust build artifacts (includes the program keypair under target/deploy).
# Keep only the IDL + generated types — the worker services (scripts/) import them.
.anchor
target/*
!target/idl
!target/types
target/idl/*
!target/idl/fluxperp.json
target/types/*
!target/types/fluxperp.ts
**/*.rs.bk

# Node / Next.js
node_modules
app/.next
app/out
**/*.tsbuildinfo

# Local env & secrets — never commit
.env
.env.local
.env.*.local
*-keypair.json
*.pem
scripts/.maker.json
scripts/.taker.json

# Tooling / OS / editor
.yarn
test-ledger
.claude
.vercel
*.log
.DS_Store