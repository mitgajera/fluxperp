# ---- Public RPC endpoints (exposed to the browser) ----
NEXT_PUBLIC_SOLANA_L1_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_ER_RPC=https://devnet-as.magicblock.app
NEXT_PUBLIC_ER_WS=wss://devnet-as.magicblock.app
NEXT_PUBLIC_MAGIC_ROUTER_RPC=https://devnet-router.magicblock.app

# ---- Faucet (server-only) ----
# JSON array secret key of the USDC mint authority (the id.json used to init the market).
# Required for /api/faucet to mint test USDC. NEVER use a mainnet authority here.
FAUCET_SECRET=[1,2,3,...]

# ---- Faucet rate-limit store (optional, recommended on Vercel) ----
# Without these the cooldown falls back to per-instance memory and is NOT reliable on
# serverless. Provision a Vercel KV / Upstash Redis store and paste its REST creds.
KV_REST_API_URL=
KV_REST_API_TOKEN=
